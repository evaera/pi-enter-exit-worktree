{
  "name": "pi-enter-exit-worktree",
  "version": "0.1.0",
  "description": "Enter, create, and exit managed Git worktrees while moving the live Pi session",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "git",
    "worktree"
  ],
  "files": [
    "index.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.7",
    "@types/node": "^24.0.0",
    "typebox": "^1.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "npm run check && npm test"
  },
  "engines": {
    "node": ">=20"
  }
}
